{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://stac-extensions.github.io/vpp/v0.1.0/schema.json#",
  "title": "Vegetation Phenology and Productivity Extension",
  "description": "STAC Vegetation Phenology and Productivity (VPP) Extension for STAC Catalogs, STAC Collections and STAC Items.",
  "type": "object",
  "required": [
    "stac_extensions",
    "type"
  ],
  "properties": {
    "stac_extensions": {
      "type": "array",
      "contains": {
        "const": "https://stac-extensions.github.io/vpp/v0.1.0/schema.json"
      }
    },
    "type": {
      "type": "string",
      "enum": [
        "Collection",
        "Feature"
      ]
    },
    "assets": {
      "$comment": "This validates the fields in Item Assets, but does not require them.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/fields"
      }
    },
    "assetTemplates": {
      "$comment": "This validates the fields in asset templates.",
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/fields"
      }
    }
  },
  "oneOf": [
    {
      "$comment": "This validates the fields in the item properties.",
      "type": "object",
      "required": ["type", "properties"],
      "properties": {
        "type": {
          "const": "Feature"
        },
        "properties": {
          "$ref": "#/definitions/fields"
        }
      }
    },
    {
      "$comment": "This is the schema for top-level fields and item assets in STAC Collections.",
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "const": "Collection"
        },
        "summaries": {
          "$ref": "#/definitions/summaries"
        },
        "item_assets": {
          "$comment": "This validates the fields in item assets.",
          "type": "object",
          "additionalProperties": {
            "$ref": "#/definitions/fields"
          }
        }
      },
      "allOf": [
        {
          "$ref": "#/definitions/fields"
        }
      ]
    }
  ],
  "definitions": {
    "vpp:season": {
      "type": "string",
      "enum": [
        "S1",
        "S2"
      ]
    },
    "vpp:sub_parameter": {
      "type": "string",
      "enum": [
        "AMPL",
        "EOSD",
        "EOSV",
        "LENGTH",
        "LSLOPE",
        "MAXD",
        "MAXV",
        "MINV",
        "QA",
        "RSLOPE",
        "SOSD",
        "SOSV",
        "SPROD",
        "TPROD"
      ]
    },
    "fields": {
      "$comment": "Don't require the fields here as they would be required in all places where we reference the fields as possibly allowed.",
      "type": "object",
      "properties": {
        "vpp:season": {
          "$ref": "#/definitions/vpp:season"
        },
        "vpp:sub_parameter": {
          "$ref": "#/definitions/vpp:sub_parameter"
        }
      },
      "patternProperties": {
        "^(?!vpp:)": {}
      },
      "additionalProperties": false
    },
    "summaries": {
      "type": "object",
      "properties": {
        "vpp:season": {
          "type": ["array", "object"],
          "items": {
            "$ref": "#/definitions/vpp:season"
          }
        },
        "vpp:sub_parameter": {
          "type": ["array", "object"],
          "items": {
            "$ref": "#/definitions/vpp:sub_parameter"
          }
        }
      },
      "patternProperties": {
        "^(?!vpp:)": {}
      },
      "additionalProperties": false
    }
  }
}
